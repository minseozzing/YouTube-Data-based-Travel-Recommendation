# =========================
# Common
# =========================
APP_ENV=production
TZ=Asia/Seoul
DB_EXTERNAL_NETWORK=dahaeng-db-net

# =========================
# Backend (Spring Boot)
# =========================
OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com
OPENAI_API_KEY=replace-with-openai-api-key

DB_URL=jdbc:mysql://mysql:3306/dahaeng
DB_USERNAME=replace-with-db-username
DB_PASSWORD=replace-with-db-password

MONGODB_URI=mongodb://mongodb:27017/dahaeng
HDFS_NAMENODE_URI=hdfs://namenode:9000
HDFS_TRIP_BRONZE_ROOT=/data/bronze/flight/trip_com
HDFS_TRIP_SILVER_ROOT=/data/silver/flight/trip_com_daily_prices
HDFS_FLIGHT_SUMMARY_SILVER_ROOT=/data/silver/flight/flight_summary
TRIP_HEADLESS=1
HEADLESS=1
DDL_AUTO=validate

JWT_SECRET=replace-with-strong-jwt-secret
JWT_ACCESS_EXPIRATION=360000000
JWT_REFRESH_EXPIRATION=604800000

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/login/oauth2/code/google

FRONT_CALLBACK_URL=https://your-domain.com/
INTERNAL_IMAGE_UPLOAD_ENABLED=false
INTERNAL_IMAGE_UPLOAD_MAX_FILES=5

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_S3_BUCKET=replace-with-s3-bucket-name
AWS_S3_ARN=arn:aws:s3:::replace-with-s3-bucket-name

NEWS_API_KEY=replace-with-news-api-key
NEWS_API_BASE_URL=https://newsapi.org
GOOGLE_PLACES_API_KEY=replace-with-google-places-api-key
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com

DB_HOST=mysql_host
DB_PORT=mysql_port
DB_NAME=dahaeng

REDIS_HOST=my-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

GEOAPIFY_API_KEY=replace-with-geoapify-api-key
GEOAPIFY_BASE_URL=https://api.geoapify.com
GEOAPIFY_CATEGORY=tourism.sights
GEOAPIFY_RADIUS_METERS=10000
GEOAPIFY_LIMIT=20

# =========================
# Frontend (Vite)
# =========================
VITE_API_BASE_URL=/api
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id
VITE_ENABLE_MSW=false
